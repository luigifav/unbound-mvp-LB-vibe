# Chave de API para autenticar requisições à UnblockPay
UNBLOCKPAY_API_KEY=

# URL base da API da UnblockPay (sandbox para testes, trocar pela URL de produção ao publicar)
UNBLOCKPAY_BASE_URL=https://api.sandbox.unblockpay.com

# Segredo para validar webhooks recebidos da UnblockPay
# Gerar com: openssl rand -hex 32
# URL para registrar na UnblockPay: [NEXT_PUBLIC_APP_URL]/api/webhooks/unblockpay
# O mesmo valor deve ser configurado no painel da UnblockPay (Settings > Webhooks)
UNBLOCKPAY_WEBHOOK_SECRET=

# Segredo aleatório usado pelo NextAuth para assinar sessões e tokens
# Gerar com: openssl rand -hex 32
NEXTAUTH_SECRET=

# URL pública usada pelo NextAuth para redirecionar após login/logout
NEXTAUTH_URL=https://unbound-mvp.vercel.app

# URL pública da aplicação — usada para construir URLs absolutas (ex: link do webhook)
# Em produção, substituir pela URL real do projeto
NEXT_PUBLIC_APP_URL=https://luzdiaria.com/

# Supabase — criar projeto em https://supabase.com e copiar de Settings > API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
