# Resend — envio de emails (https://resend.com)
# RESEND_API_KEY: criar conta e gerar em resend.com/api-keys
# RESEND_FROM_EMAIL: remetente verificado no Resend.
#   Sem domínio próprio use "onboarding@resend.dev" (envia apenas para o dono da conta Resend — só para testes).
#   Em produção, verifique seu domínio em resend.com/domains e use algo como "Unbound <noreply@seudominio.com>"
RESEND_API_KEY=
RESEND_FROM_EMAIL=Unbound <onboarding@resend.dev>

# WhatsApp — link exibido no e-mail enviado quando o KYC é aprovado
# O link pode incluir uma mensagem pré-preenchida via parâmetro "text"
WHATSAPP_LINK=https://wa.me/5511936186784?text=Ol%C3%A1%2C%20meu%20KYC%20foi%20conclu%C3%ADdo%2C%20quero%20saber%20mais%20sobre%20como%20transacionar%20agora!
