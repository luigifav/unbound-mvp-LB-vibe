# Chave de API da UnblockPay — obtida no painel do desenvolvedor da UnblockPay
UNBLOCKPAY_API_KEY=

# URL base da API da UnblockPay (sandbox para testes, produção para deploy final)
UNBLOCKPAY_BASE_URL=https://api.sandbox.unblockpay.com

# Segredo para validar webhooks recebidos da UnblockPay
# Gerar com: openssl rand -hex 32
# O mesmo valor deve ser configurado no painel da UnblockPay ao registrar o webhook
UNBLOCKPAY_WEBHOOK_SECRET=

# Segredo utilizado pelo NextAuth para assinar sessões — deve ser uma string aleatória longa
# Gerar com: openssl rand -hex 32
NEXTAUTH_SECRET=

# URL canônica da aplicação usada pelo NextAuth para callbacks de autenticação
NEXTAUTH_URL=https://unbound-mvp.vercel.app

# URL pública da aplicação — usada para construir links absolutos no frontend e no webhook
# Exemplo local: http://localhost:3000
NEXT_PUBLIC_APP_URL=https://luzdiaria.com/

# Supabase — criar projeto em https://supabase.com e copiar de Settings > API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
